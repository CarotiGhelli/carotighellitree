// Incolla queste regole nel pannello "Firestore → Regole" della Firebase Console.
// Accesso pubblico: chiunque abbia il link può leggere e modificare l'albero.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /trees/{treeId} {
      allow read, write: if true;
    }
  }
}
